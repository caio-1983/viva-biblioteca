# =============================================================================
# Viva Biblioteca — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env
#
# IMPORTANTE: todos os valores abaixo são lidos pelo docker-compose.yml.
# Nunca edite variáveis diretamente no compose — edite apenas o .env.
# =============================================================================


# -----------------------------------------------------------------------------
# POSTGRESQL — Credenciais do container de banco
# As credenciais abaixo devem coincidir com os valores em DATABASE_URL.
# -----------------------------------------------------------------------------

POSTGRES_DB=biblioteca
POSTGRES_USER=biblioteca
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION


# -----------------------------------------------------------------------------
# DATABASE — Obrigatório
# -----------------------------------------------------------------------------

# URL de conexão com o PostgreSQL.
# Dentro do Docker use o hostname "postgres" (nome do serviço no compose).
# Fora do Docker (dev local) use "localhost".
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
DATABASE_URL=postgresql://biblioteca:CHANGE_ME_IN_PRODUCTION@postgres:5432/biblioteca


# -----------------------------------------------------------------------------
# APLICAÇÃO — Obrigatório
# -----------------------------------------------------------------------------

NODE_ENV=production
PORT=3000

# URL pública base da aplicação (sem barra final, com protocolo)
APP_URL=https://biblioteca.integrasolutionsia.com.br

# Caminho absoluto para o diretório de armazenamento em disco (dentro do container)
STORAGE_PATH=/app/storage


# -----------------------------------------------------------------------------
# AUTH.JS — Obrigatório em produção
# -----------------------------------------------------------------------------

# URL canônica da aplicação — usada pelo Auth.js para validar hosts confiáveis.
# Deve ser idêntica a APP_URL.
AUTH_URL=https://biblioteca.integrasolutionsia.com.br

# Segredo para assinatura de tokens JWT e cookies de sessão.
# Gere com: npx auth secret
# NUNCA reutilize o mesmo valor em ambientes diferentes.
AUTH_SECRET=CHANGE_ME_RUN_npx_auth_secret

# Permite que o Auth.js confie no host recebido via header X-Forwarded-Host
# (obrigatório quando a aplicação roda atrás de proxy reverso ou Docker).
AUTH_TRUST_HOST=true


# -----------------------------------------------------------------------------
# OPCIONAL
# -----------------------------------------------------------------------------

# NEXT_TELEMETRY_DISABLED=1


# -----------------------------------------------------------------------------
# LEGACY — apenas para script de migração SQLite → PostgreSQL
# -----------------------------------------------------------------------------

# SQLITE_URL=file:./storage/database/biblioteca.db
